# MongoDB Connection URI
# Local: mongodb://localhost:27017/safestride
# Cloud: mongodb+srv://<user>:<pass>@cluster.mongodb.net/safestride
MONGO_URI=mongodb://localhost:27017/safestride

# Backend Server Port
PORT=8000

# Twilio SMS Configuration
# Get these from your Twilio Console (https://www.twilio.com/console)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# OpenRouteService API Key (for navigation)
# Get it from: https://openrouteservice.org/dev/#/signup
ORS_API_KEY=your_ors_api_key_here

# API Authentication Key (optional — leave empty for dev mode)
# When set, all endpoints require X-API-Key header
SAFESTRIDE_API_KEY=
